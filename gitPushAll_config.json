{
    "_metadata": {
        "project": "Git Push All",
        "version": "1.1",
        "lastUpdated": "2026-03-19",
        "description": "Batch Git commit and push configuration"
    },
    "scan_directories": [
        "~/Documents/script",
        "~/Documents/sites",
        "~/Documents/devNotes"
    ],
    "excluded_repos": [],
    "default_commit_message": "Auto-commit: {timestamp}",
    "auto_push": true,
    "dry_run_first": false,
    "successAudio": "https://cb9-09.s3.us-east-1.amazonaws.com/siteaudio/beep-10.wav",
    "failureAudio": "~/Documents/script/gitPushAll/audio/tunetank.com_bad-file.wav"
}